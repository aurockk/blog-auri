---
import TerminalPrompt from './TerminalPrompt.astro'
import type { CollectionEntry } from 'astro:content'

type Props = {
	thoughts: CollectionEntry<'thoughts'>[]
}

const { thoughts } = Astro.props

const formatTimestamp = (date: Date) =>
	date
		.toLocaleString('es-AR', {
			year: 'numeric',
			month: '2-digit',
			day: '2-digit',
			hour: '2-digit',
			minute: '2-digit'
		})
		.replace(',', '')

const getYouTubeId = (url: string) => {
	const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\s]+)/)
	return match?.[1] ?? null
}

const getHostname = (url: string) => {
	try {
		return new URL(url).hostname
	} catch {
		return url
	}
}

const rendered = await Promise.all(
	thoughts.map(async (thought) => {
		const { Content } = await thought.render()
		const ytId = thought.data.video ? getYouTubeId(thought.data.video) : null
		const linkHost = thought.data.link?.url ? getHostname(thought.data.link.url) : null
		return { data: thought.data, Content, ytId, linkHost }
	})
)
---

<ul class='feed-list'>
	{
		rendered.map(({ data, Content, ytId, linkHost }) => (
			<li class='feed-entry'>
				<span class='feed-timestamp'>[{formatTimestamp(data.pubDate)}]</span>
				<div class='feed-content'>
					<Content />
					{data.image && (
						<div class='feed-media'>
							<img src={data.image} alt='' class='feed-image' loading='lazy' />
						</div>
					)}
					{data.localVideo && (
						<div class='feed-media'>
							<video src={data.localVideo} controls class='feed-video' preload='metadata' />
						</div>
					)}
					{data.video &&
						(ytId ? (
							<div class='feed-media feed-video-wrap'>
								<iframe
									src={`https://www.youtube.com/embed/${ytId}`}
									frameborder='0'
									allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture'
									allowfullscreen
									class='feed-iframe'
									loading='lazy'
								/>
							</div>
						) : (
							<div class='feed-media'>
								<video src={data.video} controls class='feed-video' />
							</div>
						))}
					{data.link && (
						<a
							href={data.link.url}
							target='_blank'
							rel='noopener noreferrer'
							class='feed-link-card'
						>
							<span class='feed-link-arrow'>→</span>
							<span class='feed-link-text'>{data.link.title || data.link.url}</span>
							{linkHost && <span class='feed-link-host'>{linkHost}</span>}
						</a>
					)}
				</div>
			</li>
		))
	}
</ul>

<TerminalPrompt />

<style>
	.feed-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.4rem;
	}

	.feed-entry {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		border-bottom: 1px solid var(--border);
		padding-bottom: 1.2rem;
	}

	.feed-entry:last-child {
		border-bottom: none;
	}

	.feed-timestamp {
		color: var(--hot, var(--amber));
		font-size: 0.8rem;
		letter-spacing: 1px;
	}

	.feed-content {
		color: var(--ink);
		max-width: 760px;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.feed-content :global(p) {
		margin: 0;
	}

	.feed-media {
		margin-top: 0.2rem;
	}

	.feed-image {
		max-width: 100%;
		max-height: 420px;
		object-fit: cover;
		border: 1px solid var(--border);
		border-radius: 4px;
		display: block;
	}

	.feed-video-wrap {
		position: relative;
		padding-bottom: 56.25%;
		height: 0;
		overflow: hidden;
		border: 1px solid var(--border);
		border-radius: 4px;
	}

	.feed-iframe {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		border: none;
	}

	.feed-video {
		max-width: 100%;
		border: 1px solid var(--border);
		border-radius: 4px;
		display: block;
	}

	.feed-link-card {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 0.6rem 0.9rem;
		border: 1px solid var(--border);
		border-radius: 4px;
		text-decoration: none;
		color: var(--ink);
		background: var(--panel);
		transition: border-color 0.15s;
	}

	.feed-link-card:hover {
		border-color: var(--accent);
		color: var(--accent);
	}

	.feed-link-arrow {
		color: var(--accent);
		font-size: 0.9rem;
	}

	.feed-link-text {
		font-size: 0.93rem;
		font-weight: 500;
	}

	.feed-link-host {
		font-size: 0.75rem;
		color: var(--dim);
	}
</style>
